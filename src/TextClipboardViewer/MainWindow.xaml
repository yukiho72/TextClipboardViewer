<Window x:Class="TextClipboardViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TextClipboardViewer"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ResizeMode="CanResize"
        Width="320" Height="180" MinWidth="120" MinHeight="60"
        MouseEnter="OnMouseEnterWindow" MouseLeave="OnMouseLeaveWindow">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="8" GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <Style x:Key="HoverButton" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Background" Value="#33FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#66FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Border x:Name="RootBorder" CornerRadius="8" PreviewMouseLeftButtonDown="OnBorderMouseDown">
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="{DynamicResource Main_Ctx_Hide}" Click="OnHideClick"/>
                <Separator/>
                <MenuItem Header="{DynamicResource Main_Ctx_Exit}" Click="OnExitClick"/>
            </ContextMenu>
        </Border.ContextMenu>
        <Grid>
            <ScrollViewer Margin="12,30,12,12" Background="Transparent"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <TextBlock x:Name="ClipText" TextWrapping="Wrap"
                           Text="{DynamicResource Main_Placeholder}"/>
            </ScrollViewer>
            <StackPanel x:Name="HoverButtons" Orientation="Horizontal"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,6,8,0" Opacity="0">
                <Button x:Name="ClearButton" Content="&#x1F5D1;"
                        Style="{StaticResource HoverButton}" Click="OnClearClick"
                        ToolTip="{DynamicResource Main_Tip_Clear}"/>
                <Button x:Name="SettingsButton" Content="&#x2699;" Margin="6,0,0,0"
                        Style="{StaticResource HoverButton}" Click="OnSettingsClick"
                        ToolTip="{DynamicResource Main_Tip_Settings}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
