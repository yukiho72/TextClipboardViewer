<Window x:Class="TextClipboardViewer.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Main_Tip_Settings}" Width="260" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False"
        MouseLeftButtonDown="OnDragMove">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="Label">
            <Setter Property="Foreground" Value="#999999"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
        </Style>
    </Window.Resources>
    <Border Background="#F0252528" CornerRadius="10" Padding="14">
        <StackPanel>
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="&#x2715;" Width="20" Height="20"
                        Background="Transparent" Foreground="#AAAAAA" BorderThickness="0"
                        Cursor="Hand" Click="OnCloseClick"/>
                <TextBlock Text="{DynamicResource Settings_Title}" Foreground="#E5E5E5"
                           FontSize="12" FontWeight="SemiBold"/>
            </DockPanel>

            <TextBlock Text="{DynamicResource Settings_Preset}" Style="{StaticResource Label}"/>
            <UniformGrid Columns="2">
                <Button Content="{DynamicResource Settings_PresetDark}" Margin="0,0,4,4" Padding="0,5" Click="OnPresetDark"/>
                <Button Content="{DynamicResource Settings_PresetLight}" Margin="0,0,0,4" Padding="0,5" Click="OnPresetLight"/>
                <Button Content="{DynamicResource Settings_PresetTranslucent}" Margin="0,0,4,0" Padding="0,5" Click="OnPresetTranslucent"/>
                <Button Content="{DynamicResource Settings_PresetTransparent}" Padding="0,5" Click="OnPresetTransparent"/>
            </UniformGrid>

            <DockPanel Margin="0,10,0,4">
                <TextBlock DockPanel.Dock="Right" Foreground="#999999" FontSize="11"
                           Text="{Binding Value, ElementName=OpacitySlider, StringFormat={}{0:0}%}"/>
                <TextBlock Text="{DynamicResource Settings_Opacity}" Foreground="#999999" FontSize="11"/>
            </DockPanel>
            <Slider x:Name="OpacitySlider" Minimum="0" Maximum="100"
                    ValueChanged="OnOpacityChanged"/>

            <DockPanel Margin="0,10,0,4">
                <TextBlock DockPanel.Dock="Right" Foreground="#999999" FontSize="11"
                           Text="{Binding Value, ElementName=FontSizeSlider, StringFormat={}{0:0}px}"/>
                <TextBlock Text="{DynamicResource Settings_FontSize}" Foreground="#999999" FontSize="11"/>
            </DockPanel>
            <Slider x:Name="FontSizeSlider" Minimum="8" Maximum="72"
                    ValueChanged="OnFontSizeChanged"/>

            <TextBlock Text="{DynamicResource Settings_Font}" Style="{StaticResource Label}"/>
            <ComboBox x:Name="FontCombo" SelectionChanged="OnFontChanged"/>

            <TextBlock Text="{DynamicResource Settings_TextColor}" Style="{StaticResource Label}"/>
            <WrapPanel x:Name="TextColorSwatches"/>
            <TextBox x:Name="TextColorHex" Margin="0,4,0,0" FontSize="11"
                     TextChanged="OnTextColorHexChanged"/>

            <TextBlock Text="{DynamicResource Settings_BackColor}" Style="{StaticResource Label}"/>
            <WrapPanel x:Name="BackColorSwatches"/>
            <TextBox x:Name="BackColorHex" Margin="0,4,0,0" FontSize="11"
                     TextChanged="OnBackColorHexChanged"/>

            <TextBlock Text="{DynamicResource Settings_Language}" Style="{StaticResource Label}"/>
            <UniformGrid Columns="2">
                <Button Content="日本語" Margin="0,0,4,0" Padding="0,5" Click="OnLangJa"/>
                <Button Content="English" Padding="0,5" Click="OnLangEn"/>
            </UniformGrid>

            <CheckBox x:Name="ClickThroughCheck" Content="{DynamicResource Common_ClickThrough}"
                      Foreground="#E5E5E5" FontSize="12" Margin="0,14,0,0"
                      Checked="OnClickThroughChanged" Unchecked="OnClickThroughChanged"/>
        </StackPanel>
    </Border>
</Window>
