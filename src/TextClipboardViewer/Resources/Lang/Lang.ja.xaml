<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">
    <!-- MainWindow -->
    <sys:String x:Key="Main_Placeholder">コピーしたテキストがここに表示されます</sys:String>
    <sys:String x:Key="Main_Ctx_Hide">非表示</sys:String>
    <sys:String x:Key="Main_Ctx_Exit">終了</sys:String>
    <sys:String x:Key="Main_Tip_Clear">クリップボードをクリア</sys:String>
    <sys:String x:Key="Main_Tip_Settings">設定</sys:String>

    <!-- Tray -->
    <sys:String x:Key="Tray_ToggleShow">表示/非表示</sys:String>
    <sys:String x:Key="Tray_Exit">終了</sys:String>

    <!-- SettingsWindow -->
    <sys:String x:Key="Settings_Title">設定 — 変更は即座に反映</sys:String>
    <sys:String x:Key="Settings_Preset">プリセット</sys:String>
    <sys:String x:Key="Settings_PresetDark">ダーク</sys:String>
    <sys:String x:Key="Settings_PresetLight">ライト</sys:String>
    <sys:String x:Key="Settings_PresetTranslucent">半透明</sys:String>
    <sys:String x:Key="Settings_PresetTransparent">透明</sys:String>
    <sys:String x:Key="Settings_Opacity">背景の不透明度</sys:String>
    <sys:String x:Key="Settings_FontSize">文字サイズ</sys:String>
    <sys:String x:Key="Settings_Font">フォント</sys:String>
    <sys:String x:Key="Settings_TextColor">文字色</sys:String>
    <sys:String x:Key="Settings_BackColor">背景色</sys:String>
    <sys:String x:Key="Settings_Language">言語 / Language</sys:String>
    <sys:String x:Key="Common_ClickThrough">クリック透過</sys:String>
</ResourceDictionary>
