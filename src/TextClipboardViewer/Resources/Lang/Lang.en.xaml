<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">
    <!-- MainWindow -->
    <sys:String x:Key="Main_Placeholder">Copied text will appear here</sys:String>
    <sys:String x:Key="Main_Ctx_Hide">Hide</sys:String>
    <sys:String x:Key="Main_Ctx_Exit">Exit</sys:String>
    <sys:String x:Key="Main_Tip_Clear">Clear clipboard</sys:String>
    <sys:String x:Key="Main_Tip_Settings">Settings</sys:String>

    <!-- Tray -->
    <sys:String x:Key="Tray_ToggleShow">Show/Hide</sys:String>
    <sys:String x:Key="Tray_Exit">Exit</sys:String>

    <!-- SettingsWindow -->
    <sys:String x:Key="Settings_Title">Settings — changes apply instantly</sys:String>
    <sys:String x:Key="Settings_Preset">Presets</sys:String>
    <sys:String x:Key="Settings_PresetDark">Dark</sys:String>
    <sys:String x:Key="Settings_PresetLight">Light</sys:String>
    <sys:String x:Key="Settings_PresetTranslucent">Translucent</sys:String>
    <sys:String x:Key="Settings_PresetTransparent">Transparent</sys:String>
    <sys:String x:Key="Settings_Opacity">Background opacity</sys:String>
    <sys:String x:Key="Settings_FontSize">Font size</sys:String>
    <sys:String x:Key="Settings_Font">Font</sys:String>
    <sys:String x:Key="Settings_TextColor">Text color</sys:String>
    <sys:String x:Key="Settings_BackColor">Background color</sys:String>
    <sys:String x:Key="Settings_Language">言語 / Language</sys:String>
    <sys:String x:Key="Common_ClickThrough">Click-through</sys:String>
</ResourceDictionary>
